<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Coffee & Co.</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #f5efe6;
    --warm-white: #faf7f2;
    --espresso: #2c1810;
    --mocha: #4a2c1a;
    --latte: #c4956a;
    --caramel: #d4a574;
    --fog: #e8ddd0;
    --text: #2c1810;
    --text-light: #7a5c4a;
    --nav-h: 68px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ===================== NAV ===================== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: var(--nav-h);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2.5rem;
    background: rgba(250, 247, 242, 0.95);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(196, 149, 106, 0.2);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--espresso);
    letter-spacing: -0.02em;
    z-index: 201;
    position: relative;
  }
  .nav-logo span { color: var(--latte); font-style: italic; }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-light);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--latte); }

  /* ---- BURGER BUTTON ---- */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    cursor: pointer;
    z-index: 201;
    position: relative;
    background: none;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .burger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--espresso);
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(.4,0,.2,1), opacity 0.2s, background 0.3s;
    transform-origin: center;
  }
  .burger-line:nth-child(1) { margin-bottom: 5px; }
  .burger-line:nth-child(3) { margin-top: 5px; }

  .burger.open .burger-line { background: var(--cream); }
  .burger.open .burger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.open .burger-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger.open .burger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- MOBILE MENU OVERLAY ---- */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 199;
    background: var(--espresso);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }
  .mobile-menu ul { list-style: none; text-align: center; }
  .mobile-menu ul li { overflow: hidden; }
  .mobile-menu ul li a {
    display: block;
    padding: 1rem 2rem;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 9vw, 3.2rem);
    font-weight: 600;
    color: var(--cream);
    text-decoration: none;
    letter-spacing: -0.01em;
    transform: translateY(40px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), opacity 0.4s, color 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .mobile-menu.open ul li:nth-child(1) a { transition-delay: 0.05s; }
  .mobile-menu.open ul li:nth-child(2) a { transition-delay: 0.10s; }
  .mobile-menu.open ul li:nth-child(3) a { transition-delay: 0.15s; }
  .mobile-menu.open ul li a { transform: translateY(0); opacity: 1; }
  .mobile-menu ul li a:hover { color: var(--caramel); }

  .mobile-menu-footer {
    margin-top: 3rem;
    text-align: center;
    color: rgba(245,239,230,0.4);
    font-size: 0.88rem;
    line-height: 1.7;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.4s 0.2s, opacity 0.4s 0.2s;
  }
  .mobile-menu.open .mobile-menu-footer { transform: translateY(0); opacity: 1; }
  .mobile-menu-footer a { color: var(--caramel); text-decoration: none; }

  /* ===================== HERO ===================== */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: var(--nav-h);
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(196,149,106,0.15) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none;
  }
  .hero-content {
    display: flex; flex-direction: column; justify-content: center;
    padding: 4rem 3rem 4rem 5rem;
    animation: fadeUp 0.9s ease forwards;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--latte); margin-bottom: 1.2rem;
  }
  .hero-tag::before { content: ''; width: 22px; height: 1px; background: var(--latte); }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 4.5vw, 4.8rem);
    line-height: 1.1; color: var(--espresso); margin-bottom: 1.2rem;
  }
  .hero h1 em { font-style: italic; color: var(--latte); }

  .hero-desc {
    font-size: 1rem; line-height: 1.8; color: var(--text-light);
    max-width: 380px; margin-bottom: 2rem;
  }
  .hero-btns { display: flex; gap: 0.8rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-block; padding: 0.85rem 1.8rem;
    background: var(--espresso); color: var(--cream); text-decoration: none;
    font-size: 0.82rem; font-weight: 500; letter-spacing: 0.09em;
    text-transform: uppercase; border-radius: 2px;
    transition: background 0.3s, transform 0.2s;
    -webkit-tap-highlight-color: transparent; touch-action: manipulation;
  }
  .btn-primary:hover { background: var(--mocha); transform: translateY(-1px); }

  .btn-secondary {
    display: inline-block; padding: 0.85rem 1.8rem;
    border: 1.5px solid var(--caramel); color: var(--mocha); text-decoration: none;
    font-size: 0.82rem; font-weight: 500; letter-spacing: 0.09em;
    text-transform: uppercase; border-radius: 2px; transition: all 0.3s;
    -webkit-tap-highlight-color: transparent; touch-action: manipulation;
  }
  .btn-secondary:hover { background: var(--caramel); color: white; }

  .hero-visual {
    display: flex; align-items: center; justify-content: center;
    padding: 4rem 4rem 4rem 1rem;
  }
  .hero-card {
    width: 100%; max-width: 380px; aspect-ratio: 3/4;
    background: var(--espresso); border-radius: 4px;
    position: relative; overflow: hidden;
    box-shadow: 20px 20px 50px rgba(44,24,16,0.28);
    animation: fadeIn 1.1s ease forwards;
  }
  .hero-card-inner {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 1.5rem;
    background: linear-gradient(135deg, #2c1810 0%, #4a2c1a 50%, #3d2216 100%);
  }
  .coffee-icon {
    width: 110px; height: 110px;
    border: 2px solid rgba(196,149,106,0.4); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; font-size: 2.8rem;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

  .hero-card-text { text-align: center; color: var(--cream); }
  .hero-card-text h3 { font-family:'Playfair Display',serif; font-size:1.6rem; font-weight:600; margin-bottom:0.3rem; }
  .hero-card-text p { color:var(--caramel); font-size:0.8rem; letter-spacing:0.12em; text-transform:uppercase; }
  .hero-card-footer {
    position: absolute; bottom:0; left:0; right:0; padding:1.2rem;
    background: rgba(0,0,0,0.28); text-align:center;
    color:rgba(245,239,230,0.7); font-size:0.8rem; letter-spacing:0.05em;
  }
  .floating-badge {
    position: absolute; top:-16px; left:-22px;
    background: var(--caramel); color:white; padding:0.7rem 1rem;
    border-radius:2px; font-size:0.78rem; font-weight:500;
    box-shadow:0 8px 24px rgba(0,0,0,0.2); transform:rotate(-3deg); white-space:nowrap;
  }

  /* ===================== SECTIONS ===================== */
  section { padding: 6rem 5rem; }

  .section-tag {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--latte); margin-bottom: 0.8rem;
  }
  .section-tag::before { content:''; width:22px; height:1px; background:var(--latte); }

  .section-title {
    font-family:'Playfair Display',serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight:700; color:var(--espresso); line-height:1.15; margin-bottom:1.2rem;
  }

  /* ===================== ABOUT ===================== */
  #about {
    background: var(--warm-white);
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
  }
  .about-text p { font-size:0.98rem; line-height:1.9; color:var(--text-light); margin-bottom:1.1rem; }
  .about-stats { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; margin-top:2rem; }
  .stat-box { padding:1.2rem; background:var(--cream); border-left:3px solid var(--latte); border-radius:2px; }
  .stat-box .num { font-family:'Playfair Display',serif; font-size:2rem; font-weight:700; color:var(--espresso); display:block; }
  .stat-box .label { font-size:0.78rem; color:var(--text-light); letter-spacing:0.05em; text-transform:uppercase; }

  .about-visual { position:relative; }
  .about-img-main {
    width:100%; aspect-ratio:4/5;
    background:linear-gradient(145deg,var(--mocha),var(--espresso));
    border-radius:4px; display:flex; align-items:center; justify-content:center;
    font-size:5rem; box-shadow:16px 16px 50px rgba(44,24,16,0.2); position:relative; overflow:hidden;
  }
  .about-img-main::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,transparent 40%,rgba(196,149,106,0.12)); }
  .about-img-accent {
    position:absolute; bottom:-1.5rem; left:-1.5rem;
    width:55%; aspect-ratio:1; background:var(--caramel); border-radius:4px;
    display:flex; align-items:center; justify-content:center; font-size:2.5rem;
    box-shadow:8px 8px 30px rgba(44,24,16,0.25);
  }

  /* ===================== MENU ===================== */
  #menu { background:var(--espresso); color:var(--cream); position:relative; overflow:hidden; }
  #menu::before {
    content:''; position:absolute; top:-300px; right:-300px;
    width:800px; height:800px;
    background:radial-gradient(circle,rgba(196,149,106,0.07) 0%,transparent 60%);
    border-radius:50%; pointer-events:none;
  }
  #menu .section-title { color:var(--cream); }
  #menu .section-tag { color:var(--caramel); }
  #menu .section-tag::before { background:var(--caramel); }

  .menu-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1rem; }
  .menu-header p { color:rgba(245,239,230,0.55); font-size:0.95rem; max-width:280px; line-height:1.7; }

  .menu-tabs { display:flex; gap:0.4rem; margin-bottom:2.5rem; flex-wrap:wrap; }
  .tab-btn {
    padding:0.55rem 1.2rem; border:1px solid rgba(196,149,106,0.3);
    background:transparent; color:rgba(245,239,230,0.6);
    font-family:'DM Sans',sans-serif; font-size:0.82rem; font-weight:500;
    letter-spacing:0.07em; text-transform:uppercase; cursor:pointer; border-radius:2px;
    transition:all 0.2s; -webkit-tap-highlight-color:transparent; touch-action:manipulation;
  }
  .tab-btn.active, .tab-btn:hover { background:var(--caramel); border-color:var(--caramel); color:white; }

  .menu-grid {
    display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
    gap:1px; background:rgba(196,149,106,0.12); border:1px solid rgba(196,149,106,0.12);
  }
  .menu-item {
    background:rgba(250,247,242,0.03); padding:1.8rem;
    display:flex; flex-direction:column; gap:0.5rem; transition:background 0.2s;
  }
  .menu-item:hover { background:rgba(196,149,106,0.1); }
  .menu-item-top { display:flex; justify-content:space-between; align-items:flex-start; }
  .menu-item h3 { font-family:'Playfair Display',serif; font-size:1.05rem; color:var(--cream); font-weight:600; max-width:180px; line-height:1.3; }
  .menu-item .price { font-family:'Playfair Display',serif; font-size:0.95rem; color:var(--caramel); font-weight:600; white-space:nowrap; }
  .menu-item p { font-size:0.83rem; color:rgba(245,239,230,0.48); line-height:1.6; }
  .menu-category { display:none; }
  .menu-category.active { display:contents; }

  /* ===================== LOCATION ===================== */
  #location { background:var(--cream); display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
  .location-info p { font-size:0.98rem; line-height:1.8; color:var(--text-light); margin-bottom:1.8rem; }

  .info-cards { display:flex; flex-direction:column; gap:0.9rem; }
  .info-card {
    display:flex; align-items:center; gap:1rem; padding:1.1rem 1.4rem;
    background:var(--warm-white); border-radius:2px; border:1px solid rgba(196,149,106,0.2);
    transition:border-color 0.2s, transform 0.2s; text-decoration:none; color:inherit;
  }
  .info-card:hover { border-color:var(--latte); transform:translateX(4px); }
  .info-card-icon { width:38px; height:38px; background:var(--espresso); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
  .info-card-text .title { font-size:0.72rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--latte); margin-bottom:0.2rem; }
  .info-card-text .value { font-size:0.9rem; color:var(--espresso); font-weight:500; }

  .hours-grid { display:grid; grid-template-columns:auto 1fr; gap:0.3rem 1.2rem; margin-top:0.3rem; }
  .hours-grid .day { font-weight:500; font-size:0.88rem; color:var(--espresso); }
  .hours-grid .time { font-size:0.88rem; color:var(--text-light); }

  .map-visual {
    aspect-ratio:4/5; background:linear-gradient(145deg,var(--fog),var(--cream));
    border-radius:4px; border:1px solid rgba(196,149,106,0.25);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    box-shadow:inset 0 0 60px rgba(196,149,106,0.08); position:relative; overflow:hidden;
  }
  .map-visual::before {
    content:''; position:absolute; inset:0;
    background-image:linear-gradient(rgba(196,149,106,0.07) 1px,transparent 1px),linear-gradient(90deg,rgba(196,149,106,0.07) 1px,transparent 1px);
    background-size:28px 28px;
  }
  .map-pin { position:relative; z-index:1; text-align:center; }
  .pin-dot {
    width:58px; height:58px; background:var(--espresso); border-radius:50%;
    display:flex; align-items:center; justify-content:center; font-size:1.5rem;
    margin:0 auto 1rem; animation:pulse 2.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100%{box-shadow:0 0 0 12px rgba(44,24,16,0.1),0 0 0 24px rgba(44,24,16,0.05)}
    50%{box-shadow:0 0 0 18px rgba(44,24,16,0.07),0 0 0 36px rgba(44,24,16,0.03)}
  }
  .map-pin h4 { font-family:'Playfair Display',serif; font-size:1.15rem; color:var(--espresso); }
  .map-pin p { font-size:0.82rem; color:var(--text-light); margin-top:0.3rem; }

  /* ===================== FOOTER ===================== */
  footer {
    background:var(--espresso); color:var(--cream); padding:3.5rem 5rem;
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:2rem;
  }
  .footer-logo { font-family:'Playfair Display',serif; font-size:1.6rem; font-weight:700; }
  .footer-logo span { color:var(--caramel); font-style:italic; }
  .footer-tagline { font-size:0.82rem; color:rgba(245,239,230,0.45); margin-top:0.35rem; }
  .footer-right { text-align:right; }
  .footer-right p { font-size:0.83rem; color:rgba(245,239,230,0.5); line-height:1.8; }
  .footer-right a { color:var(--caramel); text-decoration:none; }

  /* ===================== ANIMATIONS ===================== */
  @keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }

  /* ===================== TABLET ===================== */
  @media (max-width: 1024px) {
    nav { padding: 0 2rem; }
    section { padding: 5rem 3rem; }
    .hero-content { padding: 4rem 2rem 4rem 3rem; }
    .hero-visual { padding: 3rem 2rem 3rem 1rem; }
    #about { gap: 3rem; }
    #location { gap: 3rem; }
    footer { padding: 3rem; }
  }

  /* ===================== MOBILE ===================== */
  @media (max-width: 768px) {
    :root { --nav-h: 62px; }

    nav { padding: 0 1.2rem; }
    .nav-links { display: none; }
    .burger { display: flex; }
    .mobile-menu { display: flex; }

    /* Hero stacked */
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-content { padding: 3rem 1.4rem 2rem; order: 1; }
    .hero h1 { font-size: clamp(2.1rem, 8.5vw, 3rem); }
    .hero-desc { font-size: 0.93rem; max-width: 100%; }
    .hero-btns { gap: 0.7rem; }
    .btn-primary, .btn-secondary { padding: 0.8rem 1.5rem; font-size: 0.8rem; }
    .hero-visual { order: 2; padding: 1rem 1.4rem 3rem; justify-content: center; }
    .hero-card { max-width: 260px; }
    .floating-badge { font-size: 0.7rem; padding: 0.55rem 0.85rem; }

    /* Sections */
    section { padding: 4rem 1.4rem; }
    .section-title { font-size: clamp(1.8rem, 7vw, 2.4rem); }

    /* About stacked */
    #about { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-visual { order: -1; }
    .about-img-accent { display: none; }
    .about-stats { grid-template-columns: 1fr 1fr; gap: 0.9rem; }
    .stat-box .num { font-size: 1.7rem; }

    /* Menu */
    .menu-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .menu-header p { max-width: 100%; font-size: 0.9rem; }
    .menu-tabs { gap: 0.4rem; }
    .tab-btn { font-size: 0.78rem; padding: 0.5rem 1rem; }
    .menu-grid { grid-template-columns: 1fr; }
    .menu-item { padding: 1.3rem; }

    /* Location stacked */
    #location { grid-template-columns: 1fr; gap: 2.5rem; }
    .map-visual { aspect-ratio: 4/3; order: -1; }

    /* Footer stacked */
    footer { padding: 2.5rem 1.4rem; flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .footer-right { text-align: left; }
  }

  /* ===================== SMALL PHONES ===================== */
  @media (max-width: 400px) {
    .hero h1 { font-size: 1.9rem; }
    .hero-btns { flex-direction: column; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; }
    .about-stats { grid-template-columns: 1fr; }
    .tab-btn { font-size: 0.74rem; padding: 0.45rem 0.85rem; }
    .menu-item h3 { max-width: 100%; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Coffee <span>& Co.</span></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#menu">Menu</a></li>
    <li><a href="#location">Visit Us</a></li>
  </ul>
  <button class="burger" id="burgerBtn" aria-label="Toggle navigation" aria-expanded="false">
    <span class="burger-line"></span>
    <span class="burger-line"></span>
    <span class="burger-line"></span>
  </button>
</nav>

<!-- MOBILE MENU OVERLAY -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <ul>
    <li><a href="#about" class="mobile-link">About</a></li>
    <li><a href="#menu" class="mobile-link">Menu</a></li>
    <li><a href="#location" class="mobile-link">Visit Us</a></li>
  </ul>
  <div class="mobile-menu-footer">
    <a href="tel:7472952424">(747) 295-2424</a><br>
    Sunland Boulevard, CA
  </div>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-tag">Est. 2020 · Sunland</div>
    <h1>Where Every Cup<br>Tells a <em>Story</em></h1>
    <p class="hero-desc">A neighborhood café crafted for slow mornings, good conversations, and coffee that actually matters.</p>
    <div class="hero-btns">
      <a href="#menu" class="btn-primary">View Menu</a>
      <a href="#location" class="btn-secondary">Find Us</a>
    </div>
